---
import Layout from "../layouts/Layout.astro";

const organizers = [
  {
    name: "Eduardo Kupper",
    initials: "EK",
    image: "/team/kupper.jpeg",
    company: "Airborne Ventures",
    linkedin: "https://www.linkedin.com/in/eduardokupper/",
  },
  {
    name: "Jean Lucas Lima",
    initials: "JL",
    image: "/team/jeanlucas.jpeg",
    company: "ConfrariaTech",
    linkedin: "https://www.linkedin.com/in/jeanlucaslima",
  },
];

const ecosystem = [
  { name: "Airborne Ventures", logo: "/logos/airborne-full.svg", noFilter: true },
  { name: "ConfrariaTech", logo: "/logos/confrariatech.svg" },
];
---

<Layout
  title="Sponsorship Deck — Airborne Day"
  description="Airborne Day — Sponsorship proposal. An invite-only half-day gathering of CEOs and entrepreneurs in New York City."
>
  <div class="deck relative">
    <!-- Background pattern -->
    <div class="bg-layer pointer-events-none fixed inset-0 overflow-hidden">
      <div
        class="absolute inset-0"
        style="opacity: 0.09; background-image: linear-gradient(var(--deck-accent) 1px, transparent 1px), linear-gradient(90deg, var(--deck-accent) 1px, transparent 1px); background-size: 60px 60px;"
      ></div>
      <div class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-3xl" style="border: 1px solid rgba(67, 110, 182, 0.14);"></div>
      <div class="absolute left-1/2 top-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-2xl" style="border: 1px solid rgba(67, 110, 182, 0.09);"></div>
      <div class="absolute left-1/4 top-1/3 h-[500px] w-[500px] rounded-full blur-[120px]" style="background: rgba(67, 110, 182, 0.06);"></div>
      <div class="absolute bottom-1/4 right-1/4 h-[400px] w-[400px] rounded-full blur-[100px]" style="background: rgba(184, 134, 11, 0.04);"></div>
    </div>

    <!-- Slide 1: Cover -->
    <section class="slide relative overflow-hidden">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <img src="/logos/airborne-logo-blue.svg" alt="Airborne" class="mx-auto mb-8 h-16 w-auto" />

        <div class="mb-6 inline-flex rounded-full px-4 py-1.5 text-[11px] font-700 uppercase tracking-wider" style="border: 1px solid rgba(67, 110, 182, 0.3); background: rgba(67, 110, 182, 0.08); color: var(--deck-accent);">
          Invite Only
        </div>

        <h1 class="font-display text-5xl font-800 tracking-tight sm:text-7xl" style="color: var(--deck-text);">
          Airborne Day
        </h1>
        <p class="mt-4 font-display text-xl font-600 sm:text-2xl" style="color: var(--deck-accent);">
          Sponsorship Proposal
        </p>
        <div class="mx-auto mt-6 h-px w-24" style="background: linear-gradient(to right, transparent, var(--deck-accent), transparent);"></div>

        <p class="mx-auto mt-8 max-w-xl text-lg leading-relaxed sm:text-xl" style="color: var(--deck-muted);">
          An invite-only half-day gathering of CEOs and entrepreneurs in New York City.
        </p>

        <!-- Prominent date block -->
        <div class="mx-auto mt-10 inline-flex flex-col items-center rounded-2xl px-10 py-6" style="background: rgba(67, 110, 182, 0.06); border: 1px solid rgba(67, 110, 182, 0.12);">
          <span class="font-display text-3xl font-800 sm:text-4xl" style="color: var(--deck-text);">May 14, 2026</span>
          <span class="mt-2 font-display text-lg font-600" style="color: var(--deck-accent);">2pm &ndash; 6pm &middot; New York City</span>
          <span class="mt-1 text-xs" style="color: var(--deck-light-muted);">Tailor Partners &middot; 345 Avenue of the Americas</span>
        </div>

        <div class="mt-10 flex flex-col items-center gap-3 text-xs" style="color: var(--deck-light-muted);">
          <span class="uppercase tracking-widest">Organized by</span>
          <div class="flex items-center gap-6">
            <a href="https://www.airborne.ventures/" target="_blank" rel="noopener noreferrer" class="transition-opacity hover:opacity-70">
              <img src="/logos/airborne-full.svg" alt="Airborne Ventures" class="h-7 w-auto" />
            </a>
            <span style="color: var(--deck-border);">&middot;</span>
            <img src="/logos/confrariatech.svg" alt="ConfrariaTech" class="confraria-logo h-5" />
          </div>
        </div>
      </div>
    </section>

    <!-- Slide 2: The Event -->
    <section class="slide relative">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-4">
            <span class="font-display text-xs font-600 tracking-widest uppercase" style="color: var(--deck-accent);">The Event</span>
            <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
              Airborne Day
            </h2>
          </div>
          <div class="lg:col-span-7 lg:col-start-6">
            <p class="text-lg leading-relaxed" style="color: var(--deck-muted);">
              A curated, invite-only half-day event bringing together CEOs, founders, and entrepreneurs in New York City. Airborne Day is designed for high-signal, direct conversations between people building and leading companies at the frontier of technology and business.
            </p>
            <p class="mt-4 font-display text-lg italic" style="color: var(--deck-accent);">Small. Curated. Real.</p>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              <div class="deck-card rounded-xl p-6">
                <p class="font-display text-3xl font-800" style="background: linear-gradient(135deg, var(--deck-accent), var(--deck-accent-dim)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">1</p>
                <p class="mt-2 text-base" style="color: var(--deck-light-muted);">Half-day of immersion</p>
              </div>
              <div class="deck-card rounded-xl p-6">
                <p class="font-display text-3xl font-800" style="background: linear-gradient(135deg, var(--deck-accent), var(--deck-accent-dim)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">CEOs</p>
                <p class="mt-2 text-base" style="color: var(--deck-light-muted);">Founders & entrepreneurs</p>
              </div>
              <div class="deck-card rounded-xl p-6">
                <p class="font-display text-3xl font-800" style="background: linear-gradient(135deg, var(--deck-gold), var(--deck-gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">NYC</p>
                <p class="mt-2 text-base" style="color: var(--deck-light-muted);">New York &middot; invite only</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Slide 3: The Format -->
    <section class="slide relative">
      <div class="mx-auto max-w-5xl px-6">
        <div class="text-center">
          <span class="font-display text-xs font-600 tracking-widest uppercase" style="color: var(--deck-accent);">Schedule</span>
          <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
            The Format
          </h2>
        </div>

        <div class="mt-12 mx-auto max-w-lg">
          <div class="deck-card rounded-xl p-8" style="border-left: 4px solid var(--deck-accent);">
            <h3 class="font-display text-xl font-700" style="color: var(--deck-text);">May 14th &middot; 2pm to 6pm</h3>
            <p class="mt-1 text-sm font-600" style="color: var(--deck-accent);">New York City</p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--deck-accent);"></span>
                Networking & welcome reception
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--deck-accent);"></span>
                Talks from industry leaders and founders
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--deck-accent);"></span>
                CEO & entrepreneur roundtables
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--deck-accent);"></span>
                Space for direct conversations
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Slide 4: Why Sponsor? -->
    <section class="slide relative">
      <div class="mx-auto max-w-5xl px-6">
        <div class="text-center">
          <span class="font-display text-xs font-600 tracking-widest uppercase" style="color: var(--deck-accent);">Value Proposition</span>
          <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
            Why Sponsor?
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg" style="color: var(--deck-muted);">
            Direct access to a highly qualified group of CEOs and entrepreneurs — in a private, curated environment.
          </p>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          <div class="deck-card rounded-xl p-8">
            <span class="text-3xl">&#x1F465;</span>
            <h3 class="mt-4 font-display text-lg font-700" style="color: var(--deck-text);">Qualified audience</h3>
            <p class="mt-2 text-base leading-relaxed" style="color: var(--deck-light-muted);">
              CEOs, founders, and entrepreneurs building at the frontier of technology and business.
            </p>
          </div>
          <div class="deck-card rounded-xl p-8">
            <span class="text-3xl">&#x1F91D;</span>
            <h3 class="mt-4 font-display text-lg font-700" style="color: var(--deck-text);">Real access</h3>
            <p class="mt-2 text-base leading-relaxed" style="color: var(--deck-light-muted);">
              Small, curated format — no massive stages. Genuine conversations with decision-makers.
            </p>
          </div>
          <div class="deck-card rounded-xl p-8">
            <span class="text-3xl">&#x1F4D6;</span>
            <h3 class="mt-4 font-display text-lg font-700" style="color: var(--deck-text);">The Playbook</h3>
            <p class="mt-2 text-base leading-relaxed" style="color: var(--deck-light-muted);">
              Your brand featured in the event Playbook — a digital and printed guide distributed to all attendees.
            </p>
          </div>
          <div class="deck-card rounded-xl p-8">
            <span class="text-3xl">&#x2B50;</span>
            <h3 class="mt-4 font-display text-lg font-700" style="color: var(--deck-text);">Premium brand association</h3>
            <p class="mt-2 text-base leading-relaxed" style="color: var(--deck-light-muted);">
              Your name tied to one of the most exclusive gatherings of CEOs and entrepreneurs in New York City.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Slide 5: Sponsorship Tiers -->
    <section class="slide relative">
      <div class="mx-auto max-w-5xl px-6">
        <div class="text-center">
          <span class="font-display text-xs font-600 tracking-widest uppercase" style="color: var(--deck-accent);">Investment</span>
          <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
            Sponsorship Tiers
          </h2>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          <!-- Silver -->
          <div class="deck-card rounded-xl p-8">
            <h3 class="font-display text-lg font-700 uppercase tracking-wider" style="color: var(--deck-light-muted);">Silver</h3>
            <p class="mt-3 font-display text-4xl font-800" style="color: var(--deck-text);">$5,000 <span class="text-base font-500" style="color: var(--deck-light-muted);">USD</span></p>
            <div class="mt-6 h-px w-full" style="background: linear-gradient(to right, var(--deck-border), transparent);"></div>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Logo on website and event materials
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                1 ticket to the event
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Mention in pre and post-event communications
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Brand featured in the Playbook (digital + printed)
              </li>
            </ul>
          </div>

          <!-- Gold -->
          <div class="rounded-xl p-8" style="background: var(--deck-surface); border: 1px solid rgba(184, 134, 11, 0.3); box-shadow: 0 0 30px rgba(184, 134, 11, 0.06);">
            <div class="mb-4 inline-flex rounded-full px-3 py-1 text-[10px] font-700 uppercase tracking-wider" style="border: 1px solid rgba(184, 134, 11, 0.3); background: rgba(184, 134, 11, 0.08); color: var(--deck-gold);">
              Recommended
            </div>
            <h3 class="font-display text-lg font-700 uppercase tracking-wider" style="color: var(--deck-gold);">Gold</h3>
            <p class="mt-3 font-display text-4xl font-800" style="color: var(--deck-text);">$10,000 <span class="text-base font-500" style="color: var(--deck-light-muted);">USD</span></p>
            <div class="mt-6 h-px w-full" style="background: linear-gradient(to right, rgba(184, 134, 11, 0.3), transparent);"></div>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Everything in Silver
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                10-min sponsored talk at the event
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Co-branding on a specific session
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Post-event attendee list
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Featured speaking slot at the Download event in Brazil
              </li>
              <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
                <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Visibility at the Download event in Brazil
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Slide 6: The Download Event in Brazil -->
    <section class="slide relative">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <span class="font-display text-xs font-600 tracking-widest uppercase" style="color: var(--deck-accent);">Post-Event</span>
        <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
          The Download Event
        </h2>
        <p class="mt-2 font-display text-xl font-600" style="color: var(--deck-accent);">in Brazil</p>

        <p class="mt-8 text-lg leading-relaxed" style="color: var(--deck-muted);">
          After Airborne Day, we bring learnings and connections back to Brazil in an exclusive event for the local tech ecosystem — within 60 days of the main event.
        </p>

        <ul class="mx-auto mt-10 max-w-md space-y-4 text-left">
          <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
            <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Speakers and content straight from New York
          </li>
          <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
            <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Access to the network of CEOs and entrepreneurs from the event
          </li>
          <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
            <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Brand visibility across the Brazilian tech ecosystem
          </li>
          <li class="flex items-start gap-3 text-base" style="color: var(--deck-muted);">
            <svg class="mt-0.5 h-4 w-4 shrink-0" style="color: var(--deck-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Exclusive to Gold sponsors ($10k)
          </li>
        </ul>

        <div class="mt-10">
          <span class="inline-flex rounded-full px-5 py-2 text-xs font-700 uppercase tracking-wider" style="border: 1px solid rgba(184, 134, 11, 0.3); background: rgba(184, 134, 11, 0.08); color: var(--deck-gold);">
            Gold Tier Exclusive
          </span>
        </div>
      </div>
    </section>

    <!-- Slide 7: The Organizers -->
    <section class="slide relative">
      <div class="mx-auto max-w-4xl px-6">
        <div class="text-center">
          <span class="font-display text-xs font-600 tracking-widest uppercase" style="color: var(--deck-accent);">Leadership</span>
          <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
            The Organizers
          </h2>
          <p class="mt-4 text-lg" style="color: var(--deck-muted);">The team behind Airborne Day.</p>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 mx-auto max-w-lg">
          {organizers.map((person) => (
            <div class="deck-card flex flex-col items-center rounded-xl p-6 text-center">
              {person.image ? (
                <img
                  src={person.image}
                  alt={person.name}
                  class="h-20 w-20 rounded-full object-cover"
                  style={`border: 1px solid var(--deck-border);`}
                />
              ) : (
                <div class="flex h-20 w-20 items-center justify-center rounded-full" style="border: 1px solid var(--deck-border); background: var(--deck-raised);">
                  <span class="font-display text-lg font-700" style="color: var(--deck-accent);">{person.initials}</span>
                </div>
              )}
              <h3 class="mt-5 font-display text-lg font-700" style="color: var(--deck-text);">{person.name}</h3>
              <p class="mt-1 text-sm" style="color: var(--deck-accent);">{person.company}</p>
              <a
                href={person.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-1.5 text-sm transition-opacity hover:opacity-70"
                style="color: var(--deck-light-muted);"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
                LinkedIn
              </a>
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <p class="text-sm" style="color: var(--deck-light-muted);">
            Organized by
            <a href="https://www.airborne.ventures/" target="_blank" rel="noopener noreferrer" class="font-600 transition-opacity hover:opacity-70" style="color: var(--deck-muted);">Airborne Ventures</a>
            &
            <span class="font-600" style="color: var(--deck-muted);">ConfrariaTech</span>
          </p>
        </div>
      </div>
    </section>

    <!-- Slide 8: Ecosystem -->
    <section class="slide relative">
      <div class="mx-auto max-w-4xl px-6">
        <div class="text-center">
          <span class="font-display text-xs font-600 tracking-widest uppercase" style="color: var(--deck-accent);">Ecosystem</span>
          <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
            Who's in the Room
          </h2>
          <p class="mt-4 text-lg" style="color: var(--deck-muted);">
            Companies and leaders attending, supporting, and shaping Airborne Day.
          </p>
        </div>

        <div class="mt-12 flex flex-wrap justify-center gap-4">
          {ecosystem.map((company) => (
            <div class="flex h-20 items-center justify-center rounded-xl px-7" style="background: var(--deck-surface); border: 1px solid var(--deck-border);">
              {company.logo ? (
                <img src={company.logo} alt={company.name} class={`h-10 max-w-[120px] object-contain ${company.noFilter ? '' : 'ecosystem-logo'}`} />
              ) : (
                <span class="font-display text-base font-700" style="color: var(--deck-text);">{company.name}</span>
              )}
            </div>
          ))}
          <div class="flex h-20 items-center justify-center rounded-xl px-7" style="background: rgba(67, 110, 182, 0.04); border: 1px solid rgba(67, 110, 182, 0.1);">
            <span class="font-display text-base font-600" style="color: var(--deck-light-muted);">& more</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Slide 9: Call to Action -->
    <section class="slide relative">
      <div class="glow pointer-events-none absolute left-1/4 top-1/3 h-[500px] w-[500px] rounded-full blur-[120px]" style="background: rgba(67, 110, 182, 0.05);"></div>

      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="font-display text-3xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--deck-text);">
          Let's build this together?
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed" style="color: var(--deck-muted);">
          Sponsorship spots are limited. Get in touch to secure your tier.
        </p>

        <div class="mx-auto mt-10 grid max-w-md gap-4 sm:grid-cols-2">
          <div class="deck-card rounded-xl p-6 text-center">
            <p class="font-display text-sm font-600 uppercase tracking-wider" style="color: var(--deck-light-muted);">Silver</p>
            <p class="mt-2 font-display text-2xl font-800" style="color: var(--deck-text);">$5,000 <span class="text-sm font-500" style="color: var(--deck-light-muted);">USD</span></p>
          </div>
          <div class="rounded-xl p-6 text-center" style="background: var(--deck-surface); border: 1px solid rgba(184, 134, 11, 0.3); box-shadow: 0 0 20px rgba(184, 134, 11, 0.06);">
            <p class="font-display text-sm font-600 uppercase tracking-wider" style="color: var(--deck-gold);">Gold</p>
            <p class="mt-2 font-display text-2xl font-800" style="color: var(--deck-text);">$10,000 <span class="text-sm font-500" style="color: var(--deck-light-muted);">USD</span></p>
          </div>
        </div>

        <div class="mt-12 flex flex-col items-center gap-2 text-sm" style="color: var(--deck-light-muted);">
          <span class="font-display font-700" style="color: var(--deck-text);">May 14, 2026</span>
          <span>New York City &middot; 2pm&ndash;6pm</span>
          <div class="mt-2 flex items-center gap-3">
            <a href="https://www.airborne.ventures/" target="_blank" rel="noopener noreferrer" class="font-600 transition-opacity hover:opacity-70" style="color: var(--deck-accent);">airborne.ventures</a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <style>
    .deck {
      --deck-bg: #ECEDF5;
      --deck-surface: #F5F6FA;
      --deck-raised: #FFFFFF;
      --deck-border: #D4D6E0;
      --deck-text: #2D3042;
      --deck-muted: #3D4055;
      --deck-light-muted: #6B6E82;
      --deck-accent: #436eb6;
      --deck-accent-dim: #224d7e;
      --deck-gold: #9A7209;
    }

    .deck {
      background-color: var(--deck-bg);
    }

    .deck-card {
      background: var(--deck-surface);
      border: 1px solid var(--deck-border);
    }

    .confraria-logo,
    .ecosystem-logo {
      filter: brightness(0.25);
    }

    .slide {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    @media print {
      .slide {
        page-break-after: always;
        min-height: 100vh;
      }
      .glow,
      .bg-layer {
        display: none;
      }
      body {
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
    }
  </style>
</Layout>
