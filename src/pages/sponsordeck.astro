---
import Layout from "../layouts/Layout.astro";

const speakers = [
  { name: "Eduardo Küpper", org: "Airborne", initials: "EK" },
  { name: "Gabriela Lima", org: "BTG", initials: "GL" },
  { name: "Thaisa Kaszek", org: "Kaszek", initials: "TK" },
  { name: "Maria Fornea", org: "Endeavor", initials: "MF" },
];

// TODO: replace with real logo assets in public/logos/ for Fuerza Studio, EBB, GestãoRH, Select
const partners = [
  { name: "Airborne", logo: "/logos/airborne-full.svg" },
  { name: "Fuerza Studio", logo: null },
  { name: "EBB — Experience Beyond Business", logo: null },
  { name: "GestãoRH Startups", logo: null },
  { name: "Select", logo: null },
];

const tiers = [
  {
    name: "Bronze",
    subtitle: "Startups",
    price: "R$ 1.500",
    tagline: "Entrada no ecossistema + branding qualificado",
    highlight: false,
    perks: [
      "Logo nos materiais digitais do evento",
      "Menção nas redes sociais (1 post)",
      "Exposição da marca no telão / backdrop",
      "2 convites para o evento",
      "Inclusão no mailing pós-evento",
    ],
  },
  {
    name: "Prata",
    subtitle: null,
    price: "R$ 10.000",
    tagline: "Presença forte + relacionamento direto",
    highlight: false,
    perks: [
      "Tudo da cota Bronze",
      "3 convites para o evento",
      "1 ativação simples no evento (brinde, sampling)",
      "Logo com maior destaque nos materiais",
      "Menção no palco durante o evento",
      "Acesso à lista de participantes",
    ],
  },
  {
    name: "Ouro",
    subtitle: null,
    price: "R$ 15.000",
    tagline: "Posicionamento estratégico + geração de negócios",
    highlight: false,
    perks: [
      "Tudo da cota Prata",
      "5 convites para o evento",
      "Fala rápida no evento (pitch de 2–3 min)",
      "Branding em materiais físicos (pulseiras, copos)",
      "Destaque nas redes sociais (2 a 3 posts)",
      "Inclusão em conteúdos oficiais (vídeo / cobertura)",
    ],
  },
  {
    name: "Master",
    subtitle: "poucos slots",
    price: "R$ 30.000",
    tagline: "Posicionamento dominante",
    highlight: true,
    perks: [
      "Tudo da cota Ouro",
      "Naming rights: Sunset Connections by [Marca]",
      "6 convites para o evento",
      "Abertura oficial do evento",
      "Branding principal em TODOS os materiais",
      "Co-criação do evento (influência no público)",
      "Acesso direto a investidores e convidados estratégicos",
      "Conteúdo exclusivo pós-evento (leads + mídia)",
    ],
  },
  {
    name: "Diamante",
    subtitle: null,
    price: "R$ 50.000",
    tagline: "Destaque de primeiro nível",
    highlight: false,
    perks: [
      "Tudo da cota Master",
      "Destaque primeiro nível em toda a comunicação",
      "7 convites para o evento",
      "Espaço para apresentação ou ativação da marca",
      "Inserção prioritária em materiais físicos e digitais",
    ],
  },
];

const audience = [
  { label: "C-Level / Sócios", value: 45, color: "#ED1E3F" },
  { label: "Gerentes / Heads", value: 30, color: "#F75E77" },
  { label: "Especialistas / Consultores", value: 18, color: "#FFB4BE" },
  { label: "Outros", value: 7, color: "#FFF5F6" },
];

let acc = 0;
const stops = audience.map((a) => {
  const start = acc;
  acc += a.value;
  return `${a.color} ${start}% ${acc}%`;
}).join(", ");
const conic = `conic-gradient(${stops})`;

const mailSubject = encodeURIComponent("Sunset Connections 2026 — Patrocínio");
const mailBody = encodeURIComponent("Olá Marcone,\n\nGostaria de conversar sobre as cotas de patrocínio do Sunset Connections 2026 — Rio.");
const mailto = `mailto:marcone@fuerzastudio.com.br?subject=${mailSubject}&body=${mailBody}`;
const wa = "https://wa.me/5551992300046";
---

<Layout
  title="Mídia Kit · Sunset Connections 2026 · Rio"
  description="Mídia kit e cotas de patrocínio do Sunset Connections 2026 — Rio de Janeiro, 08 de Junho."
>
  <main class="relative">

    <div class="absolute top-6 left-6 z-20">
      <a href="/" class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] hover:text-[var(--color-ivory)] transition">
        ← Sunset Connections
      </a>
    </div>

    <!-- ═══ COVER ═══ -->
    <section class="relative overflow-hidden min-h-[80vh] flex items-center">
      <div class="absolute -right-40 -top-40 h-[520px] w-[520px] rounded-full bg-[var(--color-accent-dim)] opacity-90"></div>
      <div class="absolute right-[-140px] top-[60px] h-[420px] w-[420px] rounded-full bg-[var(--color-accent)]"></div>
      <div class="absolute -right-24 -bottom-48 h-[380px] w-[380px] rounded-full bg-[var(--color-accent-dim)] opacity-80"></div>
      <div class="absolute right-[80px] -bottom-32 h-[340px] w-[340px] rounded-full bg-[var(--color-accent)]"></div>

      <div class="relative mx-auto w-full max-w-6xl px-6 py-24 sm:py-28">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">Mídia kit · Cotas de patrocínio</p>
        <h1 class="mt-6 font-display font-extrabold uppercase leading-[0.95] text-[clamp(2.5rem,8vw,6.5rem)] tracking-tight animate-hero-reveal">
          <span class="block">Sunset</span>
          <span class="flex items-center gap-4 md:gap-6">
            <span>Connections</span>
            <svg viewBox="0 0 120 60" class="inline-block h-[0.7em] w-auto flex-shrink-0" aria-hidden="true">
              <path d="M 10 55 A 40 40 0 0 1 90 55 Z" fill="var(--color-accent)" />
              <path d="M 60 55 A 40 40 0 0 1 110 55 Z" fill="var(--color-accent-dim)" opacity="0.9" />
            </svg>
          </span>
        </h1>
        <p class="mt-8 font-display font-semibold text-2xl sm:text-3xl text-[var(--color-ivory)]">
          08 de Junho de 2026 · Rio de Janeiro
        </p>
        <p class="mt-4 max-w-xl text-[var(--color-muted)]">
          Tudo o que você precisa saber para colocar sua marca dentro da sala.
        </p>

        <div class="mt-10 flex flex-wrap gap-4">
          <a href="#cotas" class="inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-6 py-3 font-semibold text-white transition hover:bg-[var(--color-accent-dim)]">
            Ver cotas de patrocínio
          </a>
          <a href="#contato" class="inline-flex items-center gap-2 rounded-full border border-[var(--color-ivory)]/30 px-6 py-3 font-semibold transition hover:border-[var(--color-ivory)]">
            Falar com o time
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ PROPOSTA ═══ -->
    <section class="relative border-y border-[var(--color-edge)]/50 py-24 sm:py-32">
      <div class="mx-auto max-w-5xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">Proposta do evento</p>
        <h2 class="mt-4 font-display font-bold text-4xl sm:text-5xl leading-tight">
          Mais do que um evento.<br />
          <span class="text-[var(--color-muted)]">Um ponto de encontro para quem constrói o futuro.</span>
        </h2>
        <div class="mt-10 grid gap-8 text-lg leading-relaxed text-[var(--color-ivory)]/85 sm:grid-cols-2">
          <p>
            O Sunset Connections é um evento exclusivo de networking que conecta
            empreendedores, investidores, executivos e líderes do ecossistema de
            inovação em um ambiente descontraído e altamente estratégico.
          </p>
          <p>
            Mais do que um evento, é um ponto de encontro para gerar conexões reais,
            negócios e oportunidades, reunindo pessoas que estão construindo o futuro.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══ O QUE É / O QUE ACONTECE ═══ -->
    <section class="relative overflow-hidden bg-[var(--color-accent)] py-24 sm:py-32 text-[var(--color-midnight)]">
      <div class="absolute -right-32 -top-32 h-[360px] w-[360px] rounded-full bg-[var(--color-accent-dim)] opacity-70"></div>
      <div class="absolute -left-24 -bottom-24 h-[280px] w-[280px] rounded-full bg-[var(--color-accent-dim)] opacity-60"></div>

      <div class="relative mx-auto max-w-6xl px-6 grid gap-12 md:grid-cols-2">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.3em] opacity-75">O que é</p>
          <h3 class="mt-3 font-display font-bold text-3xl sm:text-4xl">
            Um encontro presencial premium, com curadoria de convidados.
          </h3>
          <ul class="mt-8 space-y-3 text-lg">
            {[
              "Networking de alto nível",
              "Geração de negócios",
              "Conexão entre startups, empresas e investidores",
              "Troca de experiências entre líderes",
            ].map((it) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[var(--color-midnight)] flex-shrink-0"></span>
                {it}
              </li>
            ))}
          </ul>
          <p class="mt-8 text-base italic opacity-80">
            Tudo em um ambiente leve, que favorece conversas próximas e conexões genuínas.
          </p>
        </div>

        <div>
          <p class="font-mono text-xs uppercase tracking-[0.3em] opacity-75">O que acontece</p>
          <h3 class="mt-3 font-display font-bold text-3xl sm:text-4xl">
            Conexões estratégicas do começo ao fim.
          </h3>
          <ul class="mt-8 space-y-3 text-lg">
            {[
              "Conexões estratégicas entre participantes",
              "Apresentação de startups e negócios",
              "Interação direta com investidores",
              "Experiência social + profissional (networking qualificado)",
              "Ambiente propício para parcerias e novos projetos",
            ].map((it) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[var(--color-midnight)] flex-shrink-0"></span>
                {it}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ═══ POR QUE FAZEMOS ═══ -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-5xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">Por que fazemos</p>
        <h2 class="mt-4 font-display font-bold text-4xl sm:text-5xl leading-tight">
          O ecossistema de inovação cresce<br />
          <span class="text-[var(--color-accent)]">através de conexões.</span>
        </h2>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {[
            ["Pessoas certas", "Aproximar quem precisa estar perto — no momento certo."],
            ["Negócios & capital", "Facilitar investimentos e oportunidades comerciais."],
            ["Ecossistema", "Fortalecer a rede de startups brasileiras e latino-americanas."],
            ["Oportunidade orgânica", "Criar o ambiente onde coisas acontecem naturalmente."],
          ].map(([t, d]) => (
            <div class="rounded-2xl border border-[var(--color-edge)] bg-[var(--color-surface)]/40 p-6 transition hover:border-[var(--color-accent)]/50">
              <h3 class="font-display font-semibold text-xl text-[var(--color-ivory)]">{t}</h3>
              <p class="mt-3 text-sm text-[var(--color-muted)]">{d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ NÚMEROS ═══ -->
    <section class="relative border-y border-[var(--color-edge)]/50 py-24 sm:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">
          Sunset Connections 2026 — Porto Alegre/RS
        </p>
        <h2 class="mt-4 font-display font-bold text-4xl sm:text-5xl">Os números da última edição.</h2>

        <div class="mt-14 grid gap-6 sm:grid-cols-3">
          <div class="rounded-2xl border border-[var(--color-edge)] p-8">
            <p class="font-display font-extrabold text-6xl sm:text-7xl text-[var(--color-accent)] leading-none">377</p>
            <p class="mt-4 font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)]">Inscritos</p>
          </div>
          <div class="rounded-2xl border border-[var(--color-edge)] p-8">
            <p class="font-display font-extrabold text-6xl sm:text-7xl text-[var(--color-accent)] leading-none">4</p>
            <p class="mt-4 font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)]">Países</p>
            <p class="mt-2 text-sm text-[var(--color-ivory)]/80">Brasil · Peru · EUA · Rússia</p>
          </div>
          <div class="rounded-2xl border border-[var(--color-edge)] p-8">
            <p class="font-display font-extrabold text-6xl sm:text-7xl text-[var(--color-accent)] leading-none">6</p>
            <p class="mt-4 font-mono text-xs uppercase tracking-[0.25em] text-[var(--color-muted)]">Estados</p>
            <p class="mt-2 text-sm text-[var(--color-ivory)]/80">RS · SC · PR · SP · RJ · RN</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PERFIL DO PÚBLICO ═══ -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-6xl px-6 grid gap-16 md:grid-cols-2 items-center">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">Perfil do público</p>
          <h2 class="mt-4 font-display font-bold text-4xl sm:text-5xl leading-tight">
            Liderança e decisão<br />
            <span class="text-[var(--color-muted)]">numa sala só.</span>
          </h2>
          <p class="mt-6 text-lg text-[var(--color-ivory)]/85">
            75% do público é composto por C-Levels, sócios, gerentes e heads — pessoas
            que tomam decisões de crescimento, investimento e expansão.
          </p>
          <ul class="mt-10 space-y-4">
            {audience.map((a) => (
              <li class="flex items-center gap-4">
                <span class="h-3 w-3 rounded-full flex-shrink-0" style={`background-color: ${a.color}`}></span>
                <span class="font-display font-semibold text-lg w-14 text-right tabular-nums">{a.value}%</span>
                <span class="text-[var(--color-ivory)]/85">{a.label}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="flex justify-center">
          <div class="relative aspect-square w-full max-w-[380px]">
            <div class="absolute inset-0 rounded-full" style={`background: ${conic};`}></div>
            <div class="absolute inset-[18%] rounded-full bg-[var(--color-midnight)] flex flex-col items-center justify-center text-center p-6">
              <p class="font-display font-extrabold text-5xl text-[var(--color-accent)] leading-none">75%</p>
              <p class="mt-2 font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">Liderança<br/>& decisão</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ RESULTADO ═══ -->
    <section class="relative overflow-hidden bg-[var(--color-accent)] text-[var(--color-midnight)] py-24 sm:py-32">
      <div class="absolute -right-40 -top-32 h-[380px] w-[380px] rounded-full bg-[var(--color-accent-dim)] opacity-60"></div>
      <div class="absolute -left-32 -bottom-40 h-[340px] w-[340px] rounded-full bg-[var(--color-midnight)] opacity-20"></div>

      <div class="relative mx-auto max-w-5xl px-6 text-center">
        <p class="font-mono text-xs uppercase tracking-[0.3em] opacity-75">Resultado real</p>
        <h2 class="mt-6 font-display font-extrabold text-5xl sm:text-7xl lg:text-8xl leading-[0.95]">
          R$ 6,5 milhões
        </h2>
        <p class="mt-6 text-2xl sm:text-3xl font-display font-semibold">
          captados em investimento — a partir de conexões do Sunset.
        </p>
        <p class="mt-4 text-base opacity-75">
          Incluindo a rodada da Grit, fechada com investidores presentes no evento.
        </p>
      </div>
    </section>

    <!-- ═══ PALESTRANTES ═══ -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">Palestrantes · edição anterior</p>
        <h2 class="mt-4 font-display font-bold text-4xl sm:text-5xl">Quem já passou pelo palco.</h2>

        {/* TODO: replace initials placeholders with real photos in /public/speakers/ */}
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {speakers.map((s) => (
            <div class="rounded-2xl border border-[var(--color-edge)] p-6 transition hover:border-[var(--color-accent)]/50">
              <div class="aspect-square w-full rounded-xl bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-dim)] flex items-center justify-center">
                <span class="font-display font-extrabold text-5xl text-white tracking-tight">{s.initials}</span>
              </div>
              <h3 class="mt-5 font-display font-semibold text-xl">{s.name}</h3>
              <p class="mt-1 text-sm text-[var(--color-muted)]">{s.org}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ PARCEIROS ═══ -->
    <section class="border-y border-[var(--color-edge)]/50 py-20">
      <div class="mx-auto max-w-6xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)] text-center">Parceiros · Sunset Porto Alegre 2026</p>
        {/* TODO: add logo SVGs for Fuerza Studio, EBB, GestãoRH, Select to /public/logos/ */}
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4 sm:gap-6">
          {partners.map((p) => (
            <div class="flex items-center justify-center rounded-xl border border-[var(--color-edge)] bg-[var(--color-surface)]/40 px-6 py-4 min-h-[72px] min-w-[160px]">
              {p.logo ? (
                <img src={p.logo} alt={p.name} class="h-8 w-auto opacity-90" />
              ) : (
                <span class="font-display font-bold text-sm uppercase tracking-wider text-[var(--color-ivory)]/80">
                  {p.name}
                </span>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ DIFERENCIAIS ═══ -->
    <section class="relative overflow-hidden bg-[var(--color-accent)] text-[var(--color-midnight)] py-24 sm:py-32">
      <div class="absolute right-[-80px] top-[-80px] h-[220px] w-[220px] rounded-full bg-[var(--color-accent-dim)] opacity-70"></div>
      <div class="absolute left-[-60px] bottom-[-60px] h-[180px] w-[180px] rounded-full bg-[var(--color-accent-dim)] opacity-60"></div>

      <div class="relative mx-auto max-w-5xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] opacity-75">Diferenciais</p>
        <h2 class="mt-4 font-display font-bold text-4xl sm:text-5xl">Por que o Sunset é diferente.</h2>

        <div class="mt-14 grid gap-4 sm:grid-cols-2">
          {[
            ["Curadoria real", "Não é evento aberto — quem está na sala foi convidado."],
            ["Networking qualificado", "Quase toda conversa vira parceria, cliente ou rodada."],
            ["Ambiente premium", "Locais escolhidos para favorecer presença e conexão."],
            ["Negócios de verdade", "Já geramos R$ 6,5M em captação — e muito mais em parcerias."],
            ["Formato leve", "Sem palestras engessadas. Sem cerimônia. Só o que importa."],
          ].map(([t, d]) => (
            <div class="rounded-2xl border border-[var(--color-midnight)]/30 bg-[var(--color-midnight)]/5 p-6">
              <h3 class="font-display font-bold text-xl">{t}</h3>
              <p class="mt-2 text-sm opacity-85">{d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ COTAS ═══ -->
    <section id="cotas" class="py-24 sm:py-32 scroll-mt-8">
      <div class="mx-auto max-w-6xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">Cotas de patrocínio</p>
        <h2 class="mt-4 font-display font-bold text-4xl sm:text-5xl leading-tight">
          08 de Junho de 2026<br />
          <span class="text-[var(--color-accent)]">Rio de Janeiro.</span>
        </h2>
        <p class="mt-6 max-w-2xl text-lg text-[var(--color-ivory)]/85">
          Cinco formatos desenhados para marcas que querem estar perto de quem movimenta o ecossistema.
          Escolha o que faz sentido para o seu posicionamento.
        </p>

        <div class="mt-14 grid gap-6 lg:grid-cols-3">
          {tiers.map((t) => (
            <div class={`relative rounded-2xl border p-8 transition ${
              t.highlight
                ? "border-[var(--color-accent)] bg-[var(--color-accent)]/10 shadow-[0_0_60px_-20px_var(--color-accent)]"
                : "border-[var(--color-edge)] bg-[var(--color-surface)]/30 hover:border-[var(--color-accent)]/40"
            }`}>
              {t.highlight && (
                <span class="absolute -top-3 left-8 rounded-full bg-[var(--color-accent)] px-3 py-1 text-xs font-mono uppercase tracking-widest text-white">
                  Recomendado
                </span>
              )}
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-display font-extrabold text-2xl uppercase tracking-wide">{t.name}</h3>
                {t.subtitle && (
                  <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-muted)]">{t.subtitle}</span>
                )}
              </div>
              <p class="mt-4 font-display font-extrabold text-4xl text-[var(--color-accent)]">{t.price}</p>
              <p class="mt-2 text-sm text-[var(--color-ivory)]/80">{t.tagline}</p>

              <ul class="mt-6 space-y-2.5 text-sm">
                {t.perks.map((p) => (
                  <li class="flex items-start gap-2.5">
                    <span class="mt-1.5 h-1 w-1 rounded-full bg-[var(--color-accent)] flex-shrink-0"></span>
                    <span class="text-[var(--color-ivory)]/85">{p}</span>
                  </li>
                ))}
              </ul>

              <a href={mailto}
                class="mt-8 block rounded-full border border-[var(--color-accent)] px-5 py-2.5 text-center text-sm font-semibold text-[var(--color-accent)] transition hover:bg-[var(--color-accent)] hover:text-white">
                Quero esta cota
              </a>
            </div>
          ))}
        </div>
      </div>
