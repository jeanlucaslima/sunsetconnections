---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";

const pricing = [
  { tier: "Mantenedores", price: "US$ 1.000", note: "Membros do grupo de mantenedores" },
  { tier: "Membros Confraria", price: "US$ 1.600", note: "Membros ativos da Confraria.tech" },
  { tier: "Não membros", price: "US$ 2.000", note: "Aberto mediante convite" },
];
---

<Layout
  title="Casa — Beyond the Stage · BSV 2026"
  description="Base remota da Confraria.tech em Palo Alto. Uma semana de networking exclusivo durante o BSV 2026."
>
  <main>
    <!-- Hero with background image feel -->
    <section class="relative flex min-h-screen items-center overflow-hidden">
      <!-- Background layers -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div
          class="absolute inset-0 opacity-[0.03]"
          style="background-image: linear-gradient(var(--color-accent) 1px, transparent 1px), linear-gradient(90deg, var(--color-accent) 1px, transparent 1px); background-size: 60px 60px;"
        >
        </div>
        <div
          class="absolute left-1/4 top-1/3 h-[500px] w-[500px] rounded-full bg-amber/[0.05] blur-[120px]"
        >
        </div>
        <div
          class="absolute bottom-1/4 right-1/4 h-[400px] w-[400px] rounded-full bg-accent/[0.04] blur-[100px]"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-6 py-24">
        <div class="mx-auto max-w-3xl text-center">
          <!-- Confraria branding -->
          <div class="animate-fade-up mb-6" style="animation-delay: 0.1s;">
            <span class="font-display text-lg font-700 tracking-tight text-ivory">
              confraria.tech
            </span>
          </div>

          <!-- Title -->
          <h1
            class="animate-fade-up font-display text-5xl font-800 leading-tight tracking-tight sm:text-6xl md:text-7xl"
            style="animation-delay: 0.2s;"
          >
            <span class="bg-gradient-to-r from-accent via-accent-dim to-amber bg-clip-text text-transparent">
              Beyond the Stage
            </span>
            <span class="mt-2 block text-3xl font-600 text-subtle sm:text-4xl">BSV 2026</span>
          </h1>

          <!-- Details -->
          <div class="animate-fade-up mt-10 space-y-2" style="animation-delay: 0.35s;">
            <p class="font-display text-sm font-600 tracking-widest text-accent uppercase">
              Casa Temporária em Palo Alto
            </p>
            <p class="text-sm tracking-wide text-subtle uppercase">
              Conexões de alto nível & networking exclusivo
            </p>
            <p class="font-display text-4xl font-800 text-ivory">04 – 11 de Abril</p>
          </div>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="relative border-t border-edge/40 py-24">
      <div
        class="pointer-events-none absolute left-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-accent/20 to-transparent"
      >
      </div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-3xl">
          <span class="font-display text-xs font-600 tracking-widest text-accent uppercase">
            O Projeto
          </span>
          <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight text-ivory sm:text-4xl">
            Uma base para a comunidade.
          </h2>
          <div class="mt-8 space-y-6 text-lg leading-relaxed text-subtle">
            <p>
              Vamos montar uma <strong class="text-ivory">base remota da Confraria</strong> em Palo Alto
              durante uma semana inteira do BSV. A ideia é ter um espaço para networking de qualidade
              entre quem já vai ao evento, além de facilitar a logística.
            </p>
            <p>
              É um Airbnb compartilhado, organizado por conta própria, com preços diferenciados
              para honrar quem já faz parte da comunidade.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="relative border-t border-edge/40 py-24">
      <div
        class="pointer-events-none absolute left-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-accent/20 to-transparent"
      >
      </div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-3xl">
          <span class="font-display text-xs font-600 tracking-widest text-accent uppercase">
            Valores
          </span>
          <h2 class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight text-ivory sm:text-4xl">
            Estadia completa na casa
          </h2>
          <p class="mt-4 text-sm text-subtle">04 a 11 de Abril, 2026 — Palo Alto, CA</p>

          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            {pricing.map((item, i) => (
              <div
                class:list={[
                  "animate-fade-up rounded-xl border bg-surface p-6 text-center",
                  i === 0
                    ? "border-accent/40 shadow-[0_0_20px_rgba(0,232,123,0.06)]"
                    : "border-edge/60",
                ]}
                style={`animation-delay: ${i * 100}ms`}
              >
                <p class:list={[
                  "font-display text-sm font-700 uppercase tracking-wider",
                  i === 0 ? "text-accent" : "text-subtle",
                ]}>
                  {item.tier}
                </p>
                <p class="mt-4 font-display text-4xl font-800 text-ivory">
                  {item.price}
                </p>
                <p class="mt-3 text-xs text-muted">{item.note}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24">
      <div class="mx-auto max-w-7xl px-6 text-center">
        <h2 class="font-display text-3xl font-800 tracking-tight text-ivory sm:text-4xl">
          Quero participar
        </h2>
        <p class="mx-auto mt-4 max-w-lg text-lg leading-relaxed text-subtle">
          Vagas limitadas. Entre em contato para reservar seu lugar na casa.
        </p>
        <div class="mt-10">
          <a
            href="https://wa.me/5511958493835"
            class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 text-sm font-600 text-midnight transition-all hover:shadow-[0_0_30px_rgba(0,232,123,0.25)]"
          >
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
