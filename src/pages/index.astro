---
import Layout from "../layouts/Layout.astro";

const mailSubject = encodeURIComponent("Sunset Connections 2026 — Quero participar");
const mailBody = encodeURIComponent("Olá Marcone,\n\nTenho interesse em participar do Sunset Connections 2026 no Rio.");
const mailto = `mailto:marcone@fuerzastudio.com.br?subject=${mailSubject}&body=${mailBody}`;
---

<Layout title="Sunset Connections 2026 · 08 de Junho · Rio de Janeiro">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Sunset Connections 2026 — Rio",
    "description": "Evento exclusivo de networking que conecta empreendedores, investidores, executivos e líderes do ecossistema de inovação.",
    "startDate": "2026-06-08",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "eventStatus": "https://schema.org/EventScheduled",
    "location": {
      "@type": "Place",
      "name": "Rio de Janeiro",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Rio de Janeiro",
        "addressRegion": "RJ",
        "addressCountry": "BR"
      }
    },
    "organizer": {
      "@type": "Organization",
      "name": "Fuerza Studio",
      "url": "https://fuerzastudio.com.br"
    }
  })} />

  <main class="relative">

    <!-- ═══ HERO ═══ -->
    <section class="relative overflow-hidden min-h-screen flex items-center">
      <!-- Decorative arcs -->
      <div class="absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-accent-dim)] opacity-90"></div>
      <div class="absolute right-[-140px] top-[60px] h-[440px] w-[440px] rounded-full bg-[var(--color-accent)]"></div>
      <div class="absolute -right-24 -bottom-48 h-[400px] w-[400px] rounded-full bg-[var(--color-accent-dim)] opacity-80"></div>
      <div class="absolute right-[100px] -bottom-36 h-[360px] w-[360px] rounded-full bg-[var(--color-accent)]"></div>

      <div class="relative mx-auto w-full max-w-6xl px-6 py-24 sm:py-32">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/10 px-4 py-1.5 text-xs font-mono tracking-[0.2em] uppercase text-[var(--color-accent)]">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] animate-shimmer"></span>
            08 · Jun · 2026 — Rio de Janeiro
          </div>

          <h1 class="mt-8 font-display font-extrabold uppercase leading-[0.95] text-[clamp(2.75rem,9vw,7rem)] tracking-tight animate-hero-reveal">
            <span class="block">Sunset</span>
            <span class="flex items-center gap-4 md:gap-6">
              <span>Connections</span>
              <svg viewBox="0 0 120 60" class="inline-block h-[0.7em] w-auto flex-shrink-0" aria-hidden="true">
                <path d="M 10 55 A 40 40 0 0 1 90 55 Z" fill="var(--color-accent)" />
                <path d="M 60 55 A 40 40 0 0 1 110 55 Z" fill="var(--color-accent-dim)" opacity="0.9" />
              </svg>
            </span>
          </h1>

          <p class="mt-10 font-display text-3xl sm:text-4xl text-[var(--color-accent)] font-semibold animate-fade-up" style="animation-delay: 0.3s;">
            A mudança começa aqui.
          </p>

          <p class="mt-6 max-w-xl text-lg text-[var(--color-muted)] animate-fade-up" style="animation-delay: 0.5s;">
            O encontro presencial premium que conecta founders, investidores e líderes
            do ecossistema de inovação. Curadoria real, conversas próximas, negócios que acontecem.
          </p>

          <div class="mt-12 flex flex-wrap gap-4 animate-fade-up" style="animation-delay: 0.7s;">
            <a href={mailto}
              class="group inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-7 py-3.5 font-semibold text-white transition hover:bg-[var(--color-accent-dim)]">
              Quero participar
              <span class="transition group-hover:translate-x-1">→</span>
            </a>
            <a href="/sponsordeck"
              class="inline-flex items-center gap-2 rounded-full border border-[var(--color-ivory)]/30 px-7 py-3.5 font-semibold text-[var(--color-ivory)] transition hover:border-[var(--color-ivory)] hover:bg-[var(--color-ivory)]/5">
              Patrocinar evento
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ SOCIAL PROOF STRIP ═══ -->
    <section class="border-y border-[var(--color-edge)]/60 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-6">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">Última edição · Porto Alegre 2026</p>
        <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <p class="font-display font-extrabold text-5xl sm:text-6xl text-[var(--color-accent)] leading-none">377</p>
            <p class="mt-3 text-sm text-[var(--color-muted)]">inscritos de 4 países</p>
          </div>
          <div>
            <p class="font-display font-extrabold text-5xl sm:text-6xl text-[var(--color-accent)] leading-none">75%</p>
            <p class="mt-3 text-sm text-[var(--color-muted)]">C-Levels, sócios e heads</p>
          </div>
          <div>
            <p class="font-display font-extrabold text-5xl sm:text-6xl text-[var(--color-accent)] leading-none">R$ 6,5M</p>
            <p class="mt-3 text-sm text-[var(--color-muted)]">captados via conexões do evento</p>
          </div>
          <div>
            <p class="font-display font-extrabold text-5xl sm:text-6xl text-[var(--color-accent)] leading-none">1 sala</p>
            <p class="mt-3 text-sm text-[var(--color-muted)]">curadoria real, não é evento aberto</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CLOSING CTA ═══ -->
    <section class="relative overflow-hidden py-28 sm:py-36">
      <div class="absolute -left-32 top-[15%] h-[300px] w-[300px] rounded-full bg-[var(--color-accent)] opacity-85"></div>
      <div class="absolute left-[100px] top-[35%] h-[220px] w-[220px] rounded-full bg-[var(--color-accent-dim)] opacity-75"></div>

      <div class="relative mx-auto max-w-5xl px-6">
        <h2 class="font-display font-extrabold text-5xl sm:text-7xl leading-[0.95]">
          Vamos começar a<br />
          <span class="text-[var(--color-accent)]">mudança</span> juntos?
        </h2>
        <p class="mt-8 max-w-xl text-lg text-[var(--color-muted)]">
          Vagas limitadas e curadoria. Se você quer estar na sala, ou quer colocar sua marca perto de quem decide, a conversa começa agora.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href={mailto} class="inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-7 py-3.5 font-semibold text-white transition hover:bg-[var(--color-accent-dim)]">
            Quero participar →
          </a>
          <a href="/sponsordeck" class="inline-flex items-center gap-2 rounded-full border border-[var(--color-ivory)]/30 px-7 py-3.5 font-semibold transition hover:border-[var(--color-ivory)]">
            Ver mídia kit & cotas
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="border-t border-[var(--color-edge)]/60 py-10">
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <svg viewBox="0 0 60 30" class="h-6 w-auto" aria-hidden="true">
            <path d="M 5 28 A 20 20 0 0 1 45 28 Z" fill="var(--color-accent)" />
            <path d="M 30 28 A 20 20 0 0 1 55 28 Z" fill="var(--color-accent-dim)" opacity="0.9" />
          </svg>
          <span class="font-display font-bold uppercase tracking-wider text-sm">Sunset Connections</span>
        </div>
        <div class="flex items-center gap-6 text-xs text-[var(--color-muted)]">
          <a href="/sponsordeck" class="hover:text-[var(--color-ivory)] transition">Mídia kit</a>
          <span>© 2026 · Realização: Fuerza Studio</span>
        </div>
      </div>
    </footer>

  </main>
</Layout>
