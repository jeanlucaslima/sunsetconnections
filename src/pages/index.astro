---
import Layout from "../layouts/Layout.astro";

const speakers = [
  { name: "Eduardo Küpper", org: "Airborne", initials: "EK" },
  { name: "Gabriela Lima", org: "BTG", initials: "GL" },
  { name: "Thaisa Kaszek", org: "Kaszek", initials: "TK" },
  { name: "Maria Fornea", org: "Endeavor", initials: "MF" },
];

// TODO: replace with real logo assets in public/logos/ for Fuerza Studio, EBB, GestãoRH, Select
const partners = [
  { name: "Airborne", logo: "/logos/airborne-full.svg" },
  { name: "Fuerza Studio", logo: null },
  { name: "EBB", logo: null },
  { name: "GestãoRH Startups", logo: null },
  { name: "Select", logo: null },
];

const year = new Date().getFullYear();

const mailSubject = encodeURIComponent("Sunset Connections 2026 — Quero participar");
const mailBody = encodeURIComponent("Olá Marcone,\n\nTenho interesse em participar do Sunset Connections 2026 no Rio.");
const mailto = `mailto:marcone@fuerzastudio.com.br?subject=${mailSubject}&body=${mailBody}`;
---

<Layout title="Sunset Connections 2026 · 08 de Junho · Rio de Janeiro">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Sunset Connections 2026 — Rio",
    "description": "Evento exclusivo de networking que conecta empreendedores, investidores, executivos e líderes do ecossistema de inovação.",
    "startDate": "2026-06-08",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "eventStatus": "https://schema.org/EventScheduled",
    "location": {
      "@type": "Place",
      "name": "Rio de Janeiro",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Rio de Janeiro",
        "addressRegion": "RJ",
        "addressCountry": "BR"
      }
    },
    "organizer": { "@type": "Organization", "name": "Fuerza Studio", "url": "https://fuerzastudio.com.br" }
  })} />

  <div class="page relative overflow-x-hidden">

    <!-- ═══ Header ═══ -->
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl" style="border-bottom: 1px solid rgba(237,30,63,0.12); background: rgba(20,24,61,0.85);">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
        <a href="/" class="group inline-flex items-center gap-3">
          <svg viewBox="0 0 60 30" class="h-6 w-auto" aria-hidden="true">
            <path d="M 5 28 A 20 20 0 0 1 45 28 Z" fill="var(--color-accent)" />
            <path d="M 30 28 A 20 20 0 0 1 55 28 Z" fill="var(--color-accent-dim)" opacity="0.9" />
          </svg>
          <span class="font-display text-sm font-extrabold uppercase tracking-wider text-[var(--color-ivory)]">Sunset Connections</span>
        </a>

        <nav class="hidden sm:flex items-center gap-2">
          <a href="#sobre" class="hud-link">Sobre</a>
          <a href="#palestrantes" class="hud-link">Palestrantes</a>
          <a href="#parceiros" class="hud-link">Parceiros</a>
          <a href="/sponsordeck" class="hud-link hud-link-accent">Mídia Kit</a>
        </nav>

        <a href="/sponsordeck" class="sm:hidden hud-link hud-link-accent">Mídia Kit</a>
      </div>
    </header>

    <!-- ═══ Hero ═══ -->
    <section class="hero-section relative flex flex-col pt-20">
      <!-- Signature arcs, right side -->
      <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-accent-dim)] opacity-90"></div>
      <div class="pointer-events-none absolute right-[-140px] top-[60px] h-[440px] w-[440px] rounded-full bg-[var(--color-accent)]"></div>
      <div class="pointer-events-none absolute -right-24 -bottom-48 h-[400px] w-[400px] rounded-full bg-[var(--color-accent-dim)] opacity-80"></div>
      <div class="pointer-events-none absolute right-[100px] -bottom-36 h-[360px] w-[360px] rounded-full bg-[var(--color-accent)]"></div>

      <div class="flex-1 min-h-[60px]"></div>
      <div class="relative mx-auto max-w-7xl px-6 pb-12 md:pb-24 w-full flex-shrink-0">
        <div class="max-w-5xl pr-6 md:pr-12">
          <div style="overflow-y: clip; overflow-x: visible;">
            <h1 class="animate-hero-reveal font-display leading-[0.85] tracking-tighter" style="animation-delay: 0.2s;">
              <span class="block text-[clamp(2.75rem,9vw,8.5rem)] font-extrabold uppercase whitespace-nowrap tracking-[-0.02em] text-[var(--color-ivory)]">SUNSET</span>
              <span class="block text-[clamp(1.75rem,5vw,5rem)] font-semibold mt-1 md:mt-2 text-[var(--color-accent)]">Connections</span>
            </h1>
          </div>

          <p class="animate-fade-up mt-6 md:mt-10 max-w-lg text-lg md:text-xl leading-relaxed text-[var(--color-muted)]" style="animation-delay: 0.5s;">
            <span class="text-[var(--color-accent)] font-semibold">A mudança começa aqui.</span>
            Encontro presencial premium que conecta founders, investidores e líderes do ecossistema de inovação.
          </p>

          <div class="animate-fade-up mt-6 md:mt-10 inline-flex flex-col items-start cockpit-card rounded-lg px-6 py-4 md:px-8 md:py-6" style="animation-delay: 0.6s;">
            <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">Data do evento</span>
            <span class="font-mono text-3xl font-bold mt-2 sm:text-4xl text-[var(--color-ivory)]">08 JUN · 2026</span>
            <div class="flex items-center gap-3 mt-3">
              <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-subtle)]">Noite</span>
              <span class="h-1 w-1 rounded-full bg-[var(--color-accent)]"></span>
              <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-subtle)]">Rio de Janeiro · RJ</span>
            </div>
            <span class="mt-3 font-mono text-[10px] text-[var(--color-subtle)]">Local a confirmar · convites por curadoria</span>
          </div>

          <p class="animate-fade-up mt-4 md:mt-8 text-xs font-mono text-[var(--color-subtle)]" style="animation-delay: 0.7s;">
            Realização por
            <a href="https://fuerzastudio.com.br" target="_blank" rel="noopener noreferrer" class="font-bold transition-opacity hover:opacity-70 text-[var(--color-accent)]">Fuerza Studio</a>
          </p>
        </div>
      </div>

      <!-- Dashed divider -->
      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: repeating-linear-gradient(90deg, rgba(237,30,63,0.15) 0, rgba(237,30,63,0.15) 8px, transparent 8px, transparent 20px);"></div>
    </section>

    <!-- ═══ Tour Banner (Sunset Tour context) ═══ -->
    <section class="relative overflow-hidden py-16" style="background: linear-gradient(135deg, #1a1f4f 0%, #12163a 40%, #0e1130 100%);">
      <div class="pointer-events-none absolute -left-20 top-1/2 h-[300px] w-[300px] -translate-y-1/2 rounded-full blur-[100px]" style="background: rgba(237, 30, 63, 0.18);"></div>
      <div class="pointer-events-none absolute -right-10 -top-10 h-[250px] w-[250px] rounded-full blur-[90px]" style="background: rgba(176, 24, 50, 0.12);"></div>

      <div class="relative mx-auto max-w-5xl px-6">
        <div class="flex flex-col items-center gap-6 text-center lg:flex-row lg:text-left lg:gap-12">
          <div class="flex-1">
            <span class="font-mono text-xs font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]/70">Sunset Tour</span>
            <h2 class="mt-2 font-display text-2xl font-extrabold tracking-tight sm:text-3xl" style="background: linear-gradient(135deg, #FFF5F6, #F75E77); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
              De Porto Alegre para o Rio.
            </h2>
            <div class="mx-auto mt-3 h-px w-16 lg:mx-0" style="background: linear-gradient(to right, rgba(237,30,63,0.5), rgba(247,94,119,0.3), transparent);"></div>
            <p class="mt-4 text-base leading-relaxed text-[var(--color-muted)]">
              O Sunset Connections começou em Porto Alegre e reuniu 377 inscritos de 4 países.
              Em 2026, a sala vai para o Rio de Janeiro — mesma curadoria, mesma densidade de conversas,
              novo ponto de encontro para quem movimenta o ecossistema.
            </p>
          </div>
          <div class="shrink-0">
            <div class="inline-flex flex-col items-center rounded-lg px-6 py-4" style="background: rgba(237,30,63,0.08); border: 1px solid rgba(237,30,63,0.22);">
              <span class="font-mono text-xs font-bold uppercase tracking-wider text-[var(--color-accent)]/80">Jun 2026</span>
              <span class="mt-1 font-display text-lg font-extrabold text-[var(--color-ivory)]">Rio de Janeiro</span>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: repeating-linear-gradient(90deg, rgba(237,30,63,0.18) 0, rgba(237,30,63,0.18) 8px, transparent 8px, transparent 20px);"></div>
    </section>

    <!-- ═══ About / Sobre ═══ -->
    <section id="sobre" class="relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-16 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">Sobre o evento</span>
            <h2 class="mt-6 font-display text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl text-[var(--color-ivory)]">
              Uma noite.<br />
              <span class="text-[var(--color-muted)]">Conexões reais.</span>
            </h2>
          </div>

          <div class="space-y-10 lg:col-span-7 lg:col-start-6">
            <p class="text-lg leading-relaxed text-[var(--color-muted)]">
              O Sunset Connections é um evento exclusivo e por curadoria, reunindo founders, investidores,
              executivos e líderes do ecossistema de inovação em um ambiente descontraído e altamente estratégico.
              Sem palestras engessadas, sem formato de congresso — só o que importa: pessoas certas, no momento certo.
            </p>
            <p class="text-lg leading-relaxed text-[var(--color-muted)]">
              Mantemos a sala pequena o bastante para que cada conversa importe. Se você lidera uma empresa,
              está levantando capital, ou construindo algo ambicioso, este é o seu encontro.
            </p>

            <!-- Stat blocks -->
            <div class="mt-14 grid gap-5 sm:grid-cols-3">
              <div class="cockpit-card rounded-lg p-8">
                <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase block text-[var(--color-accent)]">Inscritos</span>
                <span class="font-mono text-3xl font-bold block mt-2 text-[var(--color-ivory)]">377</span>
                <p class="mt-3 font-mono text-xs uppercase tracking-wider text-[var(--color-subtle)]">última edição · POA 2026</p>
              </div>
              <div class="cockpit-card rounded-lg p-8">
                <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase block text-[var(--color-accent)]">Liderança</span>
                <span class="font-mono text-3xl font-bold block mt-2 text-[var(--color-ivory)]">75%</span>
                <p class="mt-3 font-mono text-xs uppercase tracking-wider text-[var(--color-subtle)]">C-levels, sócios & heads</p>
              </div>
              <div class="cockpit-card rounded-lg p-8">
                <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase block text-[var(--color-accent)]">Captado</span>
                <span class="font-mono text-3xl font-bold block mt-2 text-[var(--color-ivory)]">R$ 6,5M</span>
                <p class="mt-3 font-mono text-xs uppercase tracking-wider text-[var(--color-subtle)]">via conexões do evento</p>
              </div>
            </div>

            <!-- Format -->
            <div class="mt-20">
              <h3 class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">O que acontece</h3>
              <div class="mt-8">
                <div class="cockpit-card rounded-lg p-8" style="border-left: 2px solid var(--color-accent);">
                  <span class="font-display text-lg font-extrabold text-[var(--color-ivory)]">
                    08 de Junho · Noite · Rio de Janeiro
                  </span>
                  <ul class="mt-6 space-y-4">
                    {[
                      "Conexões estratégicas entre participantes",
                      "Apresentação de startups e negócios",
                      "Interação direta com investidores",
                      "Ambiente propício para parcerias e novos projetos",
                    ].map((it, i) => (
                      <li class="flex items-start gap-3 text-base text-[var(--color-muted)]">
                        <span class={`mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]`} style={`animation-delay: ${i * 0.2}s;`}></span>
                        {it}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>

            <!-- Who attends -->
            <div class="mt-20">
              <h3 class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">Quem participa</h3>
              <p class="mt-8 text-base leading-relaxed text-[var(--color-muted)]">
                Curadoria real para líderes — pessoas ativamente construindo produtos, escalando empresas
                e tomando decisões que movem o ecossistema.
              </p>
              <ul class="mt-6 space-y-4">
                {[
                  "Fundadores de startups em tração e crescimento",
                  "Investidores-anjo, VCs e corporate venture",
                  "Executivos e heads de empresas conectadas à inovação",
                  "Parceiros estratégicos do ecossistema (comunidades, hubs, empresas)",
                ].map((it) => (
                  <li class="flex items-start gap-3 text-base text-[var(--color-muted)]">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                    {it}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Speakers framer ═══ -->
    <section class="relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-16 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">Palestrantes</span>
            <h2 class="mt-6 font-display text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl text-[var(--color-ivory)]">
              Quem move<br />
              <span class="text-[var(--color-muted)]">o ecossistema.</span>
            </h2>
          </div>

          <div class="space-y-10 lg:col-span-7 lg:col-start-6">
            <p class="text-lg leading-relaxed text-[var(--color-muted)]">
              Nossos palestrantes não são "professional keynote speakers". São fundadores e operadores
              ativamente construindo — compartilhando lições reais de trabalho real. Conversas sem filtro
              sobre estratégia, escala, captação e os desafios de liderar no limite do possível.
            </p>
            <p class="text-lg leading-relaxed text-[var(--color-muted)]">
              Vieram de Airborne, BTG, Kaszek, Endeavor — e a lista de 2026 está sendo montada.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Palestrantes grid ═══ -->
    <section id="palestrantes" class="relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">Edição anterior</span>
          <h2 class="mt-6 font-display text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl text-[var(--color-ivory)]">
            Quem já passou pelo palco.
          </h2>
          <p class="mt-6 text-lg text-[var(--color-muted)]">
            Sunset Connections 2026 — Porto Alegre / RS.
          </p>
        </div>

        {/* TODO: replace initials placeholders with real photos in /public/speakers/ */}
        <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4 max-w-5xl mx-auto">
          {speakers.map((s) => (
            <div class="cockpit-card rounded-xl p-8 text-center flex flex-col items-center transition-all duration-300 hover:scale-[1.02]">
              <div class="flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-dim)]">
                <span class="font-display text-lg font-bold text-white">{s.initials}</span>
              </div>
              <h3 class="mt-6 font-display text-lg font-bold text-[var(--color-ivory)]">
                {s.name}
              </h3>
              <p class="mt-1 text-sm font-mono text-[var(--color-accent)]">{s.org}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ Parceiros / Ecosystem ═══ -->
    <section id="parceiros" class="relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">Parceiros</span>
          <h2 class="mt-6 font-display text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl text-[var(--color-ivory)]">
            Quem está na sala.
          </h2>
          <p class="mt-6 text-lg text-[var(--color-muted)]">
            Empresas e marcas apoiando, participando e construindo o Sunset.
          </p>
        </div>

        {/* TODO: add logo SVGs for Fuerza Studio, EBB, GestãoRH, Select to /public/logos/ */}
        <div class="mt-16 flex flex-wrap justify-center gap-5">
          {partners.map((p) => (
            <div class="cockpit-card flex h-24 items-center justify-center rounded-xl px-8 transition-all duration-300 hover:scale-[1.02]">
              {p.logo ? (
                <img src={p.logo} alt={p.name} class="h-10 max-w-[140px] object-contain" />
              ) : (
                <span class="font-display text-base font-bold uppercase tracking-wider text-[var(--color-ivory)]">{p.name}</span>
              )}
            </div>
          ))}
          <div class="flex h-24 items-center justify-center rounded-xl px-8" style="background: rgba(237,30,63,0.05); border: 1px solid rgba(237,30,63,0.15);">
            <span class="font-mono text-sm font-bold uppercase tracking-wider text-[var(--color-subtle)]">& mais</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="relative py-40">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-accent)]">Vamos juntos?</span>
          <h2 class="mt-6 font-display text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl text-[var(--color-ivory)]">
            Interessado em participar?
          </h2>
          <p class="mt-8 text-lg text-[var(--color-muted)]">
            O Sunset Connections é por convite. Se você é founder, investidor, executivo ou quer
            colocar sua marca dentro da sala, fale com a gente.
          </p>
          <div class="mt-12 flex flex-wrap justify-center gap-4">
            <a href={mailto} class="inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-8 py-3.5 text-sm font-semibold text-white transition hover:bg-[var(--color-accent-dim)]">
              Quero participar →
            </a>
            <a href="/sponsordeck" class="inline-flex items-center gap-2 rounded-full border border-[var(--color-ivory)]/30 px-8 py-3.5 text-sm font-semibold text-[var(--color-ivory)] transition hover:border-[var(--color-ivory)]">
              Ver mídia kit & cotas
            </a>
          </div>

          <div class="mt-10 flex flex-col items-center gap-3 font-mono text-sm text-[var(--color-subtle)]">
            <span class="font-bold text-base text-[var(--color-ivory)]">08 DE JUNHO DE 2026</span>
            <span class="text-xs uppercase tracking-wider">Rio de Janeiro · Noite · Convites por curadoria</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Footer ═══ -->
    <footer class="relative overflow-hidden border-t border-[var(--color-edge)]/40">
      <!-- Setting sun -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 z-0">
        <!-- Outer halo -->
        <div
          class="absolute left-1/2 h-[1100px] w-[1100px] -translate-x-1/2 rounded-full blur-[140px]"
          style="bottom: -680px; background: radial-gradient(circle, rgba(237,30,63,0.35) 0%, rgba(237,30,63,0.15) 40%, transparent 70%);"
        >
        </div>
        <!-- Sun disc -->
        <div
          class="absolute left-1/2 h-[720px] w-[720px] -translate-x-1/2 rounded-full"
          style="bottom: -420px; background: radial-gradient(circle, #FF5A3C 0%, #ED1E3F 28%, #B01832 55%, rgba(176,24,50,0.4) 72%, transparent 85%);"
        >
        </div>
      </div>

      <div class="relative z-10 mx-auto max-w-7xl px-6 py-20 md:py-28">
        <!-- Realização -->
        <div class="text-center">
          <span class="font-mono text-[10px] font-bold tracking-[0.2em] uppercase text-[var(--color-ivory)]/35">Realização</span>
          <div class="mt-8 flex flex-col items-center gap-8 sm:flex-row sm:justify-center sm:gap-12">
            <a href="https://fuerzastudio.com.br" target="_blank" rel="noopener noreferrer" class="transition-opacity hover:opacity-70">
              <span class="font-display text-xl font-extrabold uppercase tracking-wider text-[var(--color-ivory)]">Fuerza Studio</span>
            </a>
            <span class="hidden sm:block h-8 w-px bg-[var(--color-ivory)]/10"></span>
            <div class="flex items-center gap-3">
              <svg viewBox="0 0 60 30" class="h-6 w-auto" aria-hidden="true">
                <path d="M 5 28 A 20 20 0 0 1 45 28 Z" fill="var(--color-accent)" />
                <path d="M 30 28 A 20 20 0 0 1 55 28 Z" fill="var(--color-accent-dim)" opacity="0.9" />
              </svg>
              <span class="font-display text-sm font-bold uppercase tracking-wider text-[var(--color-ivory)]/70">Sunset Connections</span>
            </div>
          </div>
          <p class="mx-auto mt-10 max-w-md text-sm leading-relaxed text-[var(--color-ivory)]/35">
            Conectando founders, investidores e líderes do ecossistema de inovação — onde as coisas acontecem.
          </p>
        </div>

        <!-- Dashed divider -->
