<section class="relative border-t border-edge/40 py-24">
  <div
    class="pointer-events-none absolute left-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-accent/20 to-transparent"
  >
  </div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span
        class="font-display text-xs font-600 tracking-widest text-accent uppercase"
        >Partners</span
      >
      <h2
        class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight text-ivory sm:text-4xl"
      >
        Built with Support
      </h2>
      <p class="mt-4 text-sm text-subtle">
        We partner with companies and communities that believe in connecting
        Brazilian builders across borders.
      </p>
    </div>

    <div class="mx-auto mt-12 grid max-w-3xl gap-4 sm:grid-cols-3">
      <div
        class="flex items-center justify-center rounded-xl border border-edge/60 bg-surface p-8"
      >
        <span class="text-sm text-muted">Partner Logo</span>
      </div>
      <div
        class="flex items-center justify-center rounded-xl border border-edge/60 bg-surface p-8"
      >
        <span class="text-sm text-muted">Partner Logo</span>
      </div>
      <div
        class="flex items-center justify-center rounded-xl border border-edge/60 bg-surface p-8"
      >
        <span class="text-sm text-muted">Partner Logo</span>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-muted">
      Interested in partnering?
      <a
        href="mailto:partners@l8p.tech"
        class="text-accent underline underline-offset-4 transition-colors hover:text-accent-dim"
        >Get in touch</a
      >
    </p>
  </div>
</section>
