---
---

<section class="relative flex min-h-screen items-center overflow-hidden pt-20">
  <!-- Grid background -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(var(--color-accent) 1px, transparent 1px), linear-gradient(90deg, var(--color-accent) 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>
    <!-- Diamond shape accent -->
    <div
      class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-3xl border border-accent/[0.06]"
    >
    </div>
    <div
      class="absolute left-1/2 top-1/2 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-2xl border border-accent/[0.04]"
    >
    </div>
    <!-- Glow spots -->
    <div
      class="absolute left-1/4 top-1/3 h-[500px] w-[500px] rounded-full bg-accent/[0.04] blur-[120px]"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 h-[400px] w-[400px] rounded-full bg-amber/[0.03] blur-[100px]"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 py-24">
    <div class="max-w-4xl">
      <!-- Eyebrow -->
      <div class="animate-fade-up mb-8" style="animation-delay: 0.1s;">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-edge bg-surface-raised/60 px-4 py-1.5 text-xs font-500 tracking-wide text-subtle uppercase"
        >
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
          Brazil + Silicon Valley
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="animate-fade-up font-display text-6xl font-800 leading-[0.95] tracking-tight sm:text-7xl md:text-8xl lg:text-9xl"
        style="animation-delay: 0.2s;"
      >
        <span class="text-ivory">L8P</span><br />
        <span
          class="bg-gradient-to-r from-accent via-accent-dim to-amber bg-clip-text text-transparent"
          >Brazil</span
        >
      </h1>

      <!-- Subheadline -->
      <p
        class="animate-fade-up mt-8 max-w-xl text-lg leading-relaxed text-subtle sm:text-xl"
        style="animation-delay: 0.35s;"
      >
        A private gathering of Brazilian founders and engineers in Silicon Valley. Small rooms. Real conversations. Builders only.
      </p>

      <!-- CTA row -->
      <div
        class="animate-fade-up mt-12 flex flex-wrap items-center gap-4"
        style="animation-delay: 0.5s;"
      >
        <a
          href="#about"
          class="group relative inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 text-sm font-600 text-midnight transition-all hover:shadow-[0_0_30px_rgba(0,232,123,0.25)]"
        >
          Learn More
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <span class="text-sm text-muted">Limited, curated attendance.</span>
      </div>

      <p class="animate-fade-up mt-4 text-xs text-muted" style="animation-delay: 0.6s;">
        April 9–10, 2026 — <a href="https://circuitlaunch.com/" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Circuit Launch</a>, Mountain View, CA — Limited to 20 participants.
      </p>
    </div>

    <!-- Side accent stat -->
    <div
      class="animate-slide-in-right absolute bottom-24 right-6 hidden flex-col items-end gap-1 lg:flex"
      style="animation-delay: 0.6s;"
    >
      <span class="font-display text-7xl font-800 leading-none bg-gradient-to-r from-accent via-accent-dim to-amber bg-clip-text text-transparent">9–10</span>
      <span class="text-xs tracking-widest text-muted uppercase">April 2026</span>
    </div>
  </div>
</section>
