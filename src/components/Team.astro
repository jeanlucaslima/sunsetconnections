---
const team = [
  {
    name: "Jean Lucas Lima",
    initials: "JL",
    company: "ConfrariaTech",
    image: "/team/jeanlucas.jpeg",
    linkedin: "https://www.linkedin.com/in/jeanlucaslima",
  },
  {
    name: "Jones Madruga",
    initials: "JM",
    company: "Nubank",
    image: "/team/jonesmadruga.png",
    linkedin: "https://www.linkedin.com/in/jonesmadruga/",
  },
  {
    name: "Reinaldo Parreiras",
    initials: "RP",
    company: "Tupii",
    image: "/team/reinaldoparr.jpeg",
    linkedin: "https://www.linkedin.com/in/reinaldoparreiras/",
  },
  {
    name: "Ed Giansante",
    initials: "EG",
    company: "Persona",
    image: "/team/ed.jpeg",
    linkedin: "https://www.linkedin.com/in/edugiansante/",
  },
];
---

<section id="team" class="relative border-t border-edge/40 py-24">
  <div
    class="pointer-events-none absolute left-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-accent/20 to-transparent"
  >
  </div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span
        class="font-display text-xs font-600 tracking-widest text-accent uppercase"
        >The Team</span
      >
      <h2
        class="mt-4 font-display text-3xl font-800 leading-tight tracking-tight text-ivory sm:text-4xl"
      >
        The people behind this event.
      </h2>
      <p class="mt-4 text-sm text-subtle">
        A small, dedicated crew connecting Brazilian builders across Silicon
        Valley.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4 max-w-5xl mx-auto">
      {team.map((member, i) => (
        <div
          class="animate-fade-up rounded-xl border border-edge/60 bg-surface p-6 text-center flex flex-col items-center"
          style={`animation-delay: ${i * 100}ms`}
        >
          {member.image ? (
            <img
              src={member.image}
              alt={member.name}
              class="h-20 w-20 rounded-full border border-edge/60 object-cover mx-auto"
            />
          ) : (
            <div class="flex h-20 w-20 items-center justify-center rounded-full border border-edge/60 bg-surface-raised">
              <span class="font-display text-lg font-700 text-accent">
                {member.initials}
              </span>
            </div>
          )}
          <h3 class="mt-5 font-display text-lg font-700 text-ivory">
            {member.name}
          </h3>
          <p class="mt-1 text-sm text-accent">{member.company}</p>
          {member.linkedin && (
            <a
              href={member.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1.5 text-sm text-subtle transition-colors hover:text-accent"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
